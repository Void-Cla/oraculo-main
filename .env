# ── Oráculo Auto-Trading · Configuração ─────────────────────────────────────
# Apenas credenciais e infra. Parâmetros de trading são hardcoded e
# autoajustados pelo ControladorAdaptativo em runtime.

# Banco de dados
DB_PATH=./dados/oraculo.sqlite

# Servidor
PORT=8000

# OpenAI — para AI Advisor (opcional, bot opera sem ela via heurística local)
GPT_API_KEY=

# Binance — preencha com suas chaves
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# Segurança — mude para true apenas quando testado em testnet
PERMITIR_CONTA_REAL=false
