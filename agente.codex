{
  "manifest_version": "1.0",
  "project": "oraculo-main",
  "description": "Manifesto de agentes para automação do Oráculo de trading.",
  "agents": [
    {
      "id": "coordinator",
      "role": "Orquestração e governança",
      "summary": "Planeja, delega tarefas, valida promoções e gerencia deploys.",
      "capabilities": ["ler_repo", "criar_tasks", "deployer_canary", "auditar"],
      "allowed_actions": ["criar_arquivo", "editar_config_db", "marcar_release"],
      "prompt_template": "Você é o Agente Coordenador. Avalie o estado do repositório e métricas; crie um plano com tarefas pequenas e delegue aos agentes especializados. Antes de promover mudanças que afetam ordens reais, gere checklist e aguarde aprovação humana." 
    },
    {
      "id": "data_collector",
      "role": "Coleta de mercado",
      "summary": "Mantém coletores REST/WS, backfill e persistência OHLCV/livro/features.",
      "capabilities": ["py-binance", "repositório_sqlite", "backfill"],
      "allowed_actions": ["persistir_ohlcv", "enfileirar_task_backfill"],
      "prompt_template": "Você é o Agente de Coleta. Garanta integridade temporal das séries; ao detectar lacunas, execute backfill; registre tudo em audit." 
    },
    {
      "id": "feature_engine",
      "role": "Geração de features",
      "summary": "Normaliza e valida features de entrada para modelos.",
      "capabilities": ["calculos.gerador_features", "testes_regressao"],
      "allowed_actions": ["salvar_features", "executar_testes_features"],
      "prompt_template": "Você é o Agente de Features. Gere features em conformidade com FEATURE_ORDER; crie testes de regressão se mudanças afetarem distribuições." 
    },
    {
      "id": "model_trainer",
      "role": "Treinamento e versionamento",
      "summary": "Treina modelos batch, avalia e publica artefatos.",
      "capabilities": ["sklearn", "joblib", "validação_time_series"],
      "allowed_actions": ["criar_modelo_batch", "gerar_metrics_report"],
      "prompt_template": "Você é o Agente de Modelagem. Execute treino batch; compare com baseline; gere relatório; proponha promoção apenas se criterios forem atendidos." 
    },
    {
      "id": "model_server",
      "role": "Serviço de inferência",
      "summary": "Serve modelos online, lida com rollback e canary.",
      "capabilities": ["GerenciadorModelo", "monitoramento_drift"],
      "allowed_actions": ["atualizar_modelo_ativo", "rollback_modelo"],
      "prompt_template": "Você é o Agente ModelServer. Mantenha o gerenciador de modelos atualizado; exponha status em RepositorioConfig." 
    },
    {
      "id": "calibration",
      "role": "Calibração",
      "summary": "Executa bandit/ewls e atualiza parâmetros de calibração.",
      "capabilities": ["calibracao.bandit", "ewls"],
      "allowed_actions": ["atualizar_calibracao"],
      "prompt_template": "Você é o Agente de Calibração. Ajuste p_conf e parâmetros de calibração; persista alterações com histórico." 
    },
    {
      "id": "llm_manager",
      "role": "Gerenciamento de LLM",
      "summary": "Gerencia LLMs locais, prompts e indexação de notícias.",
      "capabilities": ["prompt_tuning", "indexing", "fallback_heuristic"],
      "allowed_actions": ["atualizar_modelo_llm", "cache_prompts"],
      "prompt_template": "Você é o Agente LLM. Otimize prompts, gere embeddings locais e forneça score_sentimento." 
    },
    {
      "id": "signal_engine",
      "role": "Geração de sinais",
      "summary": "Executa pipeline de sinais, valida confirmações multi-timeframe e publica fila.",
      "capabilities": ["sinais.signal_engine", "probabilistic_engine"],
      "allowed_actions": ["publicar_fila_sinais", "registrar_audit_signal"],
      "prompt_template": "Você é o Agente de Sinal. Gere sinal orquestrado, inclua metadados, e publique em fila se aprovado por risco." 
    },
    {
      "id": "risk_manager",
      "role": "Avaliação de risco",
      "summary": "Avalia sinal por usuário, calcula sizing e motivos de rejeição.",
      "capabilities": ["risco.risk_engine", "sizing"],
      "allowed_actions": ["rejeitar_sinal", "aprovar_e_calcular_plano"],
      "prompt_template": "Você é o Agente de Risco. Aplique regras de risco e garanta limites por usuario; não autorize execuções que violem políticas." 
    },
    {
      "id": "executor",
      "role": "Execução de ordens",
      "summary": "Prepara e envia ordens (simuladas ou reais) e monitora resultado.",
      "capabilities": ["GerenciadorOrdens", "py-binance"],
      "allowed_actions": ["criar_ordem_market", "monitorar_execucao"],
      "prompt_template": "Você é o Agente Executor. Execute ordens de forma idempotente; registre estado e resultado; aplique retries com backoff." 
    },
    {
      "id": "observability",
      "role": "Métricas e logs",
      "summary": "Coleta métricas Prometheus, alerta e armazena logs estruturados.",
      "capabilities": ["exportar_metricas", "gerar_alertas"],
      "allowed_actions": ["criar_alerta", "exportar_dashboard"],
      "prompt_template": "Você é o Agente Observability. Monitore latência, erros e deriva; crie alertas quando thresholds forem rompidos." 
    },
    {
      "id": "qa",
      "role": "Testes e validação",
      "summary": "Gera e roda testes; valida contratos e garante qualidade antes de promoção.",
      "capabilities": ["pytest", "contratos_pydantic"],
      "allowed_actions": ["rodar_testes", "gerar_report_testes"],
      "prompt_template": "Você é o Agente QA. Execute suites de testes e valide mudanças; bloqueie promoção se falhas acima de tolerância." 
    },
    {
      "id": "devops",
      "role": "CI/CD e infra",
      "summary": "Gerencia deploys, migrações DB e scripts de bootstrap.",
      "capabilities": ["migrar_db", "criar_release"],
      "allowed_actions": ["migrar_db", "deploy_canary"],
      "prompt_template": "Você é o Agente DevOps. Aplique migrations, crie releases e garanta rollback seguros." 
    }
  ],
  "global_policies": {
    "require_human_for_real_trades": true,
    "persist_config_to_db": true,
    "env_minimum": ["DB_PATH", "AI_API_KEY|LOCAL_LLM_PATH"]
  }
}
