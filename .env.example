DB_PATH=./dados/oraculo.sqlite
PORT=8000
GPT_API_KEY=sk-proj-...          # opcional — AI Advisor usa GPT-4o-mini
BINANCE_API_KEY=                 # sua API key da Binance
BINANCE_API_SECRET=              # sua API secret da Binance
BINANCE_TESTNET=true             # true = testnet, false = conta real
PERMITIR_CONTA_REAL=false        # mude para true com cautela

# Coleta contínua de dados (acumula material real para pesquisa de edge)
ATIVAR_COLETA_CONTINUA=true               # liga o coletor contínuo no startup
COLETA_SIMBOLOS=BTCUSDT,ETHUSDT,BNBUSDT   # vazio = pares USDT primários
COLETA_INTERVALO_SEGUNDOS=60              # velas são 1m → 1 coleta/min é o natural

# Micro-trading 1-15m operacional (TESTNET-only; relaxa pisos, EV negativo permitido)
AUTO_MODO_EXPLORACAO=false                # true só para validar/exercitar o ciclo no testnet

# Governança de EDGE — gate de lucratividade da CONTA REAL (default-closed / fail-safe)
# A entrada real num símbolo só é liberada se o walk-forward provou edge líquido (net/trade>0)
# E enquanto a validação estiver fresca. Sem isso, o bot opera só testnet/exploração.
EDGE_VALIDADE_DIAS=7              # edge validado há mais que isto EXPIRA (re-validar = re-rodar backtest)
EDGE_MIN_TRADES=30               # mínimo de trades out-of-sample p/ confiar no veredito
EDGE_IC_MINIMO=0.02              # IC walk-forward mínimo (margem sobre ruído)
EDGE_MARGEM_MINIMA_PCT=0.0       # retorno líquido médio/trade mínimo p/ ligar o edge
